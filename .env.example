# Connection string for the Neon serverless Postgres database.
DATABASE_URL=

# Stripe secret key, used server-side to create Checkout sessions.
STRIPE_SECRET_KEY=

# Public base URL of the deployed app, used to build Stripe success/cancel URLs.
# Optional — the checkout function falls back to the request origin when unset.
PUBLIC_BASE_URL=

# Netlify Recorder — captures backend function executions as Replay recordings.
# UPLOADTHING_TOKEN uploads each captured request blob (set from the secret at
# deploy time). COMMIT_SHA / BRANCH_NAME / REPLAY_REPOSITORY_URL are computed and
# set by the deploy script so the recorder service replays the matching code.
UPLOADTHING_TOKEN=
