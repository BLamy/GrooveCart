# Stripe secret key, used server-side to create Checkout sessions.
STRIPE_SECRET_KEY=

# Public base URL of the deployed app, used to build Stripe success/cancel URLs.
# Optional — the checkout function falls back to the request origin when unset.
PUBLIC_BASE_URL=

# Resend order-confirmation email settings.
# In local tests, RESEND_API_BASE points at the emulator started by scripts/test.ts.
RESEND_API_KEY=
RESEND_API_BASE=
RESEND_EMULATOR_URL=

# Optional local auth emulator overrides. The test harness seeds these clients
# automatically when running tests/auth.spec.ts.
GOOGLE_EMULATOR_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_EMULATOR_URL=
APPLE_CLIENT_ID=
MICROSOFT_EMULATOR_URL=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OKTA_EMULATOR_URL=
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
CLERK_EMULATOR_URL=
CLERK_CLIENT_ID=
CLERK_CLIENT_SECRET=
EMAIL_FROM="GrooveCart <orders@groovecart.test>"

# Optional local/emulator fallback when Stripe does not return a checkout email.
ORDER_CONFIRMATION_EMAIL_FALLBACK=

# Loop QA emulated runs may provide this generic test recipient.
LOOPQA_TEST_EMAIL=
